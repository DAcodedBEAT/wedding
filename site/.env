# The base path the site is served from. GitHub Pages *project* page →
# "/<repo-name>/". Change this one line if you rename the repo, or set it
# to "/" for a user/org page or a custom domain.
#
# Feeds both Vite's asset base and the TanStack Router basepath. Also used
# by public/404.html (pathSegmentsToKeep) — see that file if you change the
# number of path segments here.
BASE_PATH=/wedding-monogram/
