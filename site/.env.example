# Copy this file to `.env.local` (gitignored) and fill in the values, or set
# them as CI secrets for the deploy workflow.

# --- Deploy base path (safe to commit; lives in .env) ------------------------
# BASE_PATH=/wedding-monogram/

# --- Seating chart: live Google Sheet ---------------------------------------
# The seating chart reads the couple's "seating chart" Google Sheet at runtime
# (read-only values.get) and falls back to the build-time snapshot if unset or
# the fetch fails. See README "Seating chart" for the security checklist.
#
# The spreadsheet ID is NOT secret (it ships in the client bundle and the sheet
# must be link-viewable anyway) — but the sheet must contain ONLY name + table
# in the read tab, and be shared "Anyone with the link → Viewer".
VITE_SHEETS_ID=12Bolg8psUM7taFx_tDGAyNB2UCBm0WoMsfNLYZSpo7A

# Seating tab name (or A1 range). Whole-tab read lets the parser find the
# header row.
VITE_SHEETS_RANGE=Sheet1

# Photo-list tab on the SAME spreadsheet (the after-ceremony group-photo list).
# Layout: optional "Note" in A1 + text in B1, then one shot per row in column A
# with a blank row between sections. Falls back to data/photos-snapshot.ts.
VITE_SHEETS_PHOTOS_RANGE=Photos

# Google API key, restricted to: (1) the Sheets API only, (2) your Pages /
# custom-domain HTTP referrers. The key is public on a static site — these
# restrictions are what keep it safe. Put the real value in .env.local, never
# in committed .env.
VITE_SHEETS_API_KEY=
