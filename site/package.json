{
  "name": "wedding-monogram-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Static wedding website (monogram, booklet, registry, searchable seating chart). Portable via src/config/wedding.ts.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "qr": "node scripts/make-qr.mjs",
    "sheets:pull": "node --experimental-strip-types --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/pull-sheets.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.15",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.2",
    "lottie-web": "^5.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
